# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# ----------------------------------------------------------------- Gemini
# Get from: https://aistudio.google.com/app/apikey
SMART_SAVER_GEMINI_API_KEY=your-gemini-api-key-here
SMART_SAVER_GEMINI_MODEL=gemini-2.5-flash

# --------------------------------------------------------------- Supabase
# Get from: Supabase dashboard → Project Settings → API
SMART_SAVER_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SMART_SAVER_SUPABASE_KEY=your-supabase-anon-key-here

# ----------------------------------------------------------------- (v1 legacy — remove after Phase 4)
# SMART_SAVER_OLLAMA_HOST=http://localhost:11434
# SMART_SAVER_CHROMA_PATH=./data/chroma
